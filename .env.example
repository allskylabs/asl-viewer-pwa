# S3 dev adapter settings (server-side only, never exposed to browser bundle)
# Copy this file to .env.local and fill in values.

S3_DEV_BUCKET=allskylabs-edge-media-dev-use1
S3_DEV_REGION=us-east-1
S3_DEV_SITE_ID=home-lab
S3_DEV_DEVICES=ASLEdge-001,ASLEdge-002,ASLEdge-003

# AWS credentials — leave blank to use ~/.aws/credentials or env vars.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
